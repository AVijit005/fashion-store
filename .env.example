# Aura Streetwear & Ink Studio — Frontend Environment Variables
# Copy this file to .env and fill in the values for your environment.
#
# Backend environment variables are configured separately in backend/.env
# See backend/.env.example for the full backend variable reference.

# ---------------------------------------------------------------------------
# Backend API (REQUIRED)
# ---------------------------------------------------------------------------
# URL of the running NestJS backend.
# Development: http://localhost:3000 (default if unset)
# Production:  https://api.yourdomain.com
VITE_API_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Razorpay (Public key — safe to expose in frontend)
# ---------------------------------------------------------------------------
# Your Razorpay Test or Live key ID (starts with rzp_test_ or rzp_live_).
# Obtain from https://dashboard.razorpay.com/app/keys
# Checkout requires a real Razorpay test/live key ID.
VITE_RAZORPAY_KEY_ID=rzp_test_your_key_here
