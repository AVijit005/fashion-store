# Ink Studio — environment variables
#
# This project is currently frontend-only and runs with NO environment
# variables. The values below are placeholders for the planned backend
# integration (Lovable Cloud / Supabase). Copy this file to `.env` once
# you start wiring real services.

# --- Lovable Cloud / Supabase (planned) ---
# VITE_SUPABASE_URL=
# VITE_SUPABASE_PUBLISHABLE_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# --- Payments (planned) ---
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
