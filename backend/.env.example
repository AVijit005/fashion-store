# Server Configuration
PORT=3000
NODE_ENV=development

# Database (Prisma)
DATABASE_URL="postgresql://aura_user:aura_password@localhost:5432/aura_db?schema=public"

# Redis (BullMQ / Caching)
REDIS_URL="redis://localhost:6379"
FRONTEND_ORIGINS="http://localhost:5173,http://localhost:3000"

# JWT Authentication
JWT_SECRET="super-secret-jwt-key-for-local-development-change-in-production"
JWT_EXPIRES_IN="15m"
REFRESH_TOKEN_EXPIRES_IN_DAYS="7"

# Razorpay Payments (For testing, use Razorpay Sandbox keys)
RAZORPAY_KEY_ID="mock_razorpay_key"
RAZORPAY_KEY_SECRET="mock_razorpay_secret"
RAZORPAY_WEBHOOK_SECRET="mock_webhook_secret"
# ^ Required. Get from: Razorpay Dashboard → Settings → Webhooks → Secret

# Storage Configuration (AWS S3 / MinIO)
# Local MinIO credentials (configured in docker-compose.yml)
AWS_ACCESS_KEY_ID="aura_admin"
AWS_SECRET_ACCESS_KEY="aura_password"
AWS_REGION="us-east-1"
AWS_S3_BUCKET="aura-studio"
AWS_S3_ENDPOINT="http://localhost:9000"
